# Optional fuzzy-perception endpoint. The demo launcher loads .env automatically.
# Exact category matching and non-perception MCP tools do not require it.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# MCP demo server
HOST=127.0.0.1
PORT=8080
AUTO_LOAD_EPISODE=0
DEMO_TASK_CONFIG=configs/demo_task.yaml
TRAJ_PATH=eval_output_demo
