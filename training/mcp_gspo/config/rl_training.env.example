# Copy this file to config/rl_training.env and edit paths for the target machine.

# Optional conda activation. Leave CONDA_ENV_NAME empty to skip activation.
export CONDA_SH="/root/miniconda3/bin/activate"
export CONDA_ENV_NAME="mcp-grpo-rl"
export PYTHON_BIN="python"
export TORCHRUN_BIN="torchrun"

# Required external model checkpoint. Trainer and rollout server must use the same base.
export MODEL_PATH="/absolute/path/to/qwen3vl-8b-sft-checkpoint"
export MODEL_TYPE="qwen3_vl"

# Local package paths.
export DATASET_PATH="${RL_STANDALONE_ROOT}/scripts/grpo_gym_dataset.json"
export OUTPUT_DIR="${RL_STANDALONE_ROOT}/output/grpo_mcp_6gpu"
export LOG_DIR="${RL_STANDALONE_ROOT}/logs"
export MCP_ROLLOUT_DEBUG_LOG="${RL_STANDALONE_ROOT}/logs/rollout_debug.log"
export MCP_TRAJECTORY_LOG_DIR="${RL_STANDALONE_ROOT}/output/trajectory_logs"
export MCP_PROMPT_PATH="${RL_STANDALONE_ROOT}/prompts/real_grpo_prompt.txt"

# GPU layout. Use disjoint devices for a production trainer + rollout pair.
export ROLLOUT_CUDA_VISIBLE_DEVICES="0"
export TRAINER_CUDA_VISIBLE_DEVICES="1"
export TENSOR_PARALLEL_SIZE="1"
export NUM_GPUS="1"

# Trainer-rollout connection.
export ROLLOUT_HOST="localhost"
export ROLLOUT_PORT="8005"
export MASTER_PORT="29551"

# GRPO defaults copied from the source run scripts.
export NUM_GENERATIONS="8"
export PER_DEVICE_TRAIN_BATCH_SIZE="1"
export GRADIENT_ACCUMULATION_STEPS="8"
export MAX_COMPLETION_LENGTH="2048"
export MAX_LENGTH="8192"
export MAX_STEPS="1000"
export LEARNING_RATE="5e-6"
export WARMUP_RATIO="0.0"
export BETA="0.04"
export DEEPSPEED_STAGE="zero2"
export FREEZE_VIT="true"
export ADVANTAGE_ESTIMATOR="ngrpo"
# Leave empty to use the per-group maximum plus an automatic margin.
export NGRPO_VIRTUAL_MAX_REWARD=""

# Rollout server defaults.
export MAX_TURNS="50"
export MAX_NEW_TOKENS="2048"
export VLLM_MAX_MODEL_LEN="8192"
export VLLM_MAX_NUM_SEQS="48"
export VLLM_GPU_MEMORY_UTILIZATION="0.8"
export VLLM_ENABLE_LORA="true"
export VLLM_MAX_LORA_RANK="128"

# MCP server topology. If setup_ssh_tunnels.sh is used, it writes this env file.
export SSH_TUNNEL_ENV="/tmp/mcp_ssh_tunnels/mcp_server_urls.env"
export AUTOSTART_TUNNELS="0"
export MCP_SERVER_URLS="http://127.0.0.1:8080/sse"
export MCP_STRICT_REAL_CONTRACT="1"
export MCP_MAX_CONCURRENT="48"
export MCP_COMPRESS_HISTORY="1"
export MCP_COMPRESS_KEEP_LAST_K="1"
export MCP_COMPRESS_LAST_OBS_MAX_CHARS="200"

# Proxy bypass is required for localhost SSE over SSH tunnels.
export no_proxy="localhost,127.0.0.1"
export NO_PROXY="localhost,127.0.0.1"
