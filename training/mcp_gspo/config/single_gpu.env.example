# Single-card rollout and preflight profile.
# Source this after config/rl_training.env or pass it as RL_TRAINING_ENV_FILE.

export ROLLOUT_CUDA_VISIBLE_DEVICES="0"
export TRAINER_CUDA_VISIBLE_DEVICES="0"
export TENSOR_PARALLEL_SIZE="1"
export NUM_GPUS="1"
export VLLM_MAX_NUM_SEQS="1"
export VLLM_GPU_MEMORY_UTILIZATION="0.70"
export MCP_MAX_CONCURRENT="1"
export NUM_GENERATIONS="2"
export GRADIENT_ACCUMULATION_STEPS="1"
export DEEPSPEED_STAGE="none"

# Do not run the rollout server and trainer concurrently on one card unless the
# chosen model fits twice with optimizer state. Use preflight before launching
# either process and measure the chosen model independently first.
